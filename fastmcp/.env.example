MCP_HTTP_PORT=8087
MCP_BIND_ADDRESS=0.0.0.0
MCP_TOOL_MODE=individual

REDIS_URL=redis://redis:6379/0
QUEUE_NAME=av-jobs

STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=/data/assets
STORAGE_TEMP_DIR=/data/staging

PUBLIC_BASE_URL=http://localhost:8087
DOWNLOAD_SIGNING_SECRET=change-me
DOWNLOAD_URL_TTL_SECONDS=3600

MAX_INGEST_BYTES=500000000
MAX_OUTPUT_BYTES=500000000
MAX_DURATION_SECONDS=3600
INGEST_TIMEOUT_SECONDS=300
INGEST_STREAM_CHUNK_BYTES=65536
INGEST_RANGE_CHUNK_BYTES=8388608

ASSET_TTL_HOURS=24
JOB_TTL_HOURS=24
CLEANUP_INTERVAL_SECONDS=900
JOB_STALE_SECONDS=0

ALLOWED_DOMAINS=cdn.discordapp.com,media.discordapp.net,googleusercontent.com,drive.google.com,docs.google.com
ALLOWED_CONTENT_TYPES=video/*,audio/*,application/octet-stream

FFMPEG_TIMEOUT_SECONDS=900
MCP_LOG_REQUESTS=false
MCP_LOG_LEVEL=INFO

DISCORD_BOT_TOKEN=
DISCORD_API_BASE=https://discord.com/api/v10
DISCORD_MAX_UPLOAD_BYTES=25000000

GOOGLE_DRIVE_CREDENTIALS_PATH=
GOOGLE_DRIVE_IMPERSONATE_USER=
GOOGLE_DRIVE_FOLDER_DEFAULT=

# Optional S3/MinIO settings
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
